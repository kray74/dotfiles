{{ if eq .chezmoi.hostname "aorus" }}
# DO NOT CHANGE THIS FILE MANUALLY!
# Generated from chezmoi template
# Use `chezmoi edit filename`

# nVidia issues
set -gx WEBKIT_DISABLE_COMPOSITING_MODE 1

# wayland
set -gx ELECTRON_OZONE_PLATFORM_HINT auto
#set -gx GDK_BACKEND wayland
#set -gx QT_QPA_PLATFORM wayland
#set -gx SDL_VIDEODRIVER wayland,x11

fish_add_path -pg "$HOME/.local/bin"
fish_add_path -pg "$CARGO_HOME/bin"
fish_add_path -pg "$GOPATH/bin"

if status is-interactive
	fish_config theme choose new-catppuccin-mocha

    if [ $TERM = xterm-kitty ]
        abbr -a --position command ssh kitten ssh
    end

    if command -v vivid >/dev/null 2>&1
        set -gx LS_COLORS (vivid generate catppuccin-mocha)
    end
end

# vpn
set -gx http_proxy socks4://127.0.0.1:10080
set -gx https_proxy socks4://127.0.0.1:10080
{{ end }}
